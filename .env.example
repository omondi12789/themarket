# ==== Core ====
ENV=development
POSTGRES_PASSWORD=changeme
JWT_SECRET=replace-with-a-64-char-random-string
JWT_REFRESH_SECRET=replace-with-a-different-64-char-random-string
TOTP_ISSUER=THEMARKET-AI
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ==== Market data providers (real, sign up for keys) ====
POLYGON_API_KEY=
TWELVEDATA_API_KEY=
ALPHAVANTAGE_API_KEY=
FINNHUB_API_KEY=

# ==== MT5 (official MetaTrader5 python package — requires a running MT5 terminal) ====
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_TERMINAL_PATH=

# ==== MetaApi (cloud fallback, free tier has account/latency limits) ====
METAAPI_TOKEN=
METAAPI_ACCOUNT_ID=

# ==== News / sentiment ====
NEWSAPI_KEY=
FINNHUB_NEWS_KEY=

# ==== Alerting ====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# ==== Hugging Face ====
HUGGINGFACE_TOKEN=

# ==== Vault (optional — production secrets management, see app/core/vault.py) ====
# Leave unset for local dev; the app falls back to the plain env vars above.
VAULT_ADDR=
VAULT_TOKEN=
VAULT_SECRET_PATH_PREFIX=
